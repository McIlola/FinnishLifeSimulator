--- !u!1001 &1174101441
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 1043763799}
    m_Modifications:
    - target: {fileID: 226493369447565005, guid: afa74880e4f2d0742b9824e803b4536c, type: 3}
      propertyPath: m_text
      value: "Wintertime in Finland is tough, but not for a seasoned Finn like you.
        Quite the opposite, this is the prime time for ice fishing, an important
        part of your routine. Trudging out of the m\xF6kki, gear in hand, you are
        ready to drill a hole in the lake, sit down and enjoy some quality time fishing
        in the wilderness. "
      objectReference: {fileID: 0}
    - target: {fileID: 226493369447565005, guid: afa74880e4f2d0742b9824e803b4536c, type: 3}
      propertyPath: m_fontSize
