    - target: {fileID: 226493369447565005, guid: afa74880e4f2d0742b9824e803b4536c, type: 3}
      propertyPath: m_text
      value: "Show off your knowledge of different mushrooms and berries by collecting
        the right ones in your handy bucket. Gain Sisu for each correctly identified
